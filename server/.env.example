PORT=3000
MONGODB_URI=mongodb://localhost:27017/doctorsoffice
REDIS_URL=redis://localhost:6379
JWT_SECRET=your-super-secret-jwt-key-change-in-production
OTP_EXPIRY=300
NODE_ENV=development

# Set to true to boot an in-process MongoDB (mongodb-memory-server) instead of
# connecting to MONGODB_URI. Handy for local dev when you don't want to install
# MongoDB. Not for production.
USE_MEMORY_DB=false
