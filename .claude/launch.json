{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "angular-client",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["ng", "serve", "--port", "4201"],
      "port": 4201,
      "cwd": "client"
    },
    {
      "name": "express-server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "cwd": "server"
    },
    {
      "name": "yjs-server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 1234,
      "cwd": "yjs-server"
    }
  ]
}
